---
// Props: page title and optional meta description
interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Practical guidance for getting the most out of AWS Free Tier services.",
} = Astro.props;

// Footer copyright year
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<!-- Sticky site header -->
		<header class="site-header">
			<div class="container">
				<a href="/" class="site-name">AWS Free Tier Guide</a>
			</div>
		</header>

		<!-- Main page content from child pages -->
		<main class="container">
			<slot />
		</main>

		<!-- Site footer -->
		<footer class="site-footer">
			<div class="container">
				<p>&copy; {year} AWS Free Tier Guide</p>
			</div>
		</footer>
	</body>
</html>

<style>
	/* Neutral palette and system font stack */
	:root {
		--color-bg: #fafafa;
		--color-surface: #ffffff;
		--color-text: #1a1a1a;
		--color-text-muted: #5c5c5c;
		--color-border: #e5e5e5;
		--color-accent: #2563eb;
		--font-sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
			"Helvetica Neue", Arial, sans-serif;
		--header-height: 3.5rem;
		--max-width: 72rem;
	}

	/* Base document styles */
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html {
		font-family: var(--font-sans);
		line-height: 1.6;
		color: var(--color-text);
		background-color: var(--color-bg);
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	/* Shared content width constraint */
	.container {
		width: 100%;
		max-width: var(--max-width);
		margin-inline: auto;
		padding-inline: 1rem;
	}

	@media (min-width: 768px) {
		.container {
			padding-inline: 1.5rem;
		}
	}

	@media (min-width: 1280px) {
		.container {
			padding-inline: 2rem;
		}
	}

	/* Sticky header bar */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		height: var(--header-height);
		display: flex;
		align-items: center;
		background-color: var(--color-surface);
		border-bottom: 1px solid var(--color-border);
		box-shadow: 0 1px 3px rgb(0 0 0 / 0.04);
	}

	.site-name {
		font-size: clamp(1rem, 2.5vw, 1.125rem);
		font-weight: 600;
		color: var(--color-text);
		text-decoration: none;
		letter-spacing: -0.01em;
	}

	.site-name:hover {
		color: var(--color-accent);
	}

	.site-name:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
		border-radius: 2px;
	}

	/* Main content area grows to push footer down */
	main {
		flex: 1;
		padding-block: 1.5rem 2.5rem;
	}

	@media (min-width: 768px) {
		main {
			padding-block: 2rem 3rem;
		}
	}

	@media (min-width: 1280px) {
		main {
			padding-block: 2.5rem 4rem;
		}
	}

	/* Footer */
	.site-footer {
		padding-block: 1.5rem;
		background-color: var(--color-surface);
		border-top: 1px solid var(--color-border);
	}

	.site-footer p {
		margin: 0;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		text-align: center;
	}
</style>
