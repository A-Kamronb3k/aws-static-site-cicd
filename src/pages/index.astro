---
import Layout from "../layouts/Layout.astro";

const alwaysFreeServices = [
	{
		name: "AWS Lambda",
		description: "Run code without servers",
		limit: "1M requests/month",
	},
	{
		name: "Amazon DynamoDB",
		description: "NoSQL database",
		limit: "25 GB storage",
	},
	{
		name: "Amazon CloudFront",
		description: "Global CDN",
		limit: "1 TB data out/month",
	},
	{
		name: "Amazon S3",
		description: "Object storage",
		limit: "Small monthly allowance",
	},
	{
		name: "Amazon CloudWatch",
		description: "Monitoring & alarms",
		limit: "10 alarms + 10 metrics",
	},
	{
		name: "Amazon SNS",
		description: "Notifications",
		limit: "1,000 emails/month",
	},
];

const costTraps = [
	{
		name: "NAT Gateway",
		detail: "~$33/month even when idle",
	},
	{
		name: "Application Load Balancer",
		detail: "~$16/month",
	},
	{
		name: "Route 53 Hosted Zone",
		detail: "$0.50/month per zone",
	},
	{
		name: "Idle Elastic IP",
		detail: "Charged when not attached",
	},
	{
		name: "RDS (new accounts)",
		detail: "No longer always-free",
	},
];
---

<Layout
	title="AWS Free Tier Survival Guide - CI/CD Working"
	description="Learn which AWS services stay free forever and which common resources quietly add to your bill."
>
	<section class="hero" aria-labelledby="hero-heading">
		<h1 id="hero-heading">AWS Free Tier Survival Guide</h1>
		<p class="hero-subtitle">Stay within free limits and avoid surprise charges on AWS.</p>
		<p class="hero-intro">
			A quick reference for the services you can rely on at no cost—and the traps that catch
			new accounts off guard.
		</p>
	</section>

	<section class="services" aria-labelledby="services-heading">
		<h2 id="services-heading">Always Free Services</h2>
		<p class="section-lead">
			These services include ongoing free allowances that do not expire after 12 months.
		</p>
		<ul class="card-grid">
			{
				alwaysFreeServices.map((service) => (
					<li class="service-card">
						<h3>{service.name}</h3>
						<p class="card-description">{service.description}</p>
						<p class="card-limit">
							<span class="visually-hidden">Free limit: </span>
							{service.limit}
						</p>
					</li>
				))
			}
		</ul>
	</section>

	<section class="traps" aria-labelledby="traps-heading">
		<h2 id="traps-heading">Cost Traps to Avoid</h2>
		<p class="section-lead">
			These resources often look harmless but can generate recurring charges from day one.
		</p>
		<ul class="trap-list">
			{
				costTraps.map((trap) => (
					<li class="trap-item">
						<span class="trap-icon" aria-hidden="true">!</span>
						<div class="trap-content">
							<h3>{trap.name}</h3>
							<p>{trap.detail}</p>
						</div>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	/* Fluid type and spacing scale */
	.hero {
		text-align: center;
		padding-block: 1.5rem 2rem;
		border-bottom: 1px solid var(--color-border, #e5e5e5);
	}

	.hero h1 {
		margin: 0 0 0.625rem;
		font-size: clamp(1.5rem, 4.5vw + 0.5rem, 2.75rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.02em;
		color: var(--color-text, #1a1a1a);
	}

	.hero-subtitle {
		margin: 0 0 0.875rem;
		font-size: clamp(0.9375rem, 2vw + 0.5rem, 1.25rem);
		color: var(--color-text-muted, #5c5c5c);
	}

	.hero-intro {
		margin: 0 auto;
		max-width: 38rem;
		font-size: clamp(0.875rem, 1.5vw + 0.5rem, 1.0625rem);
		color: var(--color-text, #1a1a1a);
	}

	.services,
	.traps {
		padding-block: 2rem;
	}

	.traps {
		border-top: 1px solid var(--color-border, #e5e5e5);
	}

	h2 {
		margin: 0 0 0.5rem;
		font-size: clamp(1.25rem, 2.5vw + 0.5rem, 1.75rem);
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.section-lead {
		margin: 0 0 1.25rem;
		max-width: 42rem;
		font-size: clamp(0.875rem, 1vw + 0.75rem, 1rem);
		color: var(--color-text-muted, #5c5c5c);
	}

	/* Single column on mobile, 2-up tablet, 3-up desktop */
	.card-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.875rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.service-card {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		padding: 1rem;
		background: var(--color-surface, #ffffff);
		border: 1px solid var(--color-border, #e5e5e5);
		border-radius: 0.5rem;
		box-shadow: 0 1px 2px rgb(0 0 0 / 0.04);
		transition:
			box-shadow 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.service-card h3 {
		margin: 0;
		font-size: clamp(0.9375rem, 1vw + 0.75rem, 1.0625rem);
		font-weight: 600;
		color: var(--color-text, #1a1a1a);
	}

	.card-description {
		margin: 0;
		flex: 1;
		font-size: clamp(0.8125rem, 1vw + 0.65rem, 0.9375rem);
		color: var(--color-text-muted, #5c5c5c);
	}

	.card-limit {
		margin: 0.375rem 0 0;
		padding-top: 0.625rem;
		border-top: 1px solid var(--color-border, #e5e5e5);
		font-size: clamp(0.8125rem, 0.5vw + 0.7rem, 0.875rem);
		font-weight: 600;
		color: #166534;
	}

	/* Hover only on pointer devices; no motion when user prefers reduced motion */
	@media (hover: hover) and (pointer: fine) {
		.service-card:hover {
			border-color: #cbd5e1;
			box-shadow: 0 4px 12px rgb(0 0 0 / 0.08);
			transform: translateY(-2px);
		}
	}

	.trap-list {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.trap-item {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 0.875rem 1rem;
		background: #fff7ed;
		border: 1px solid #fdba74;
		border-left: 4px solid #ea580c;
		border-radius: 0.5rem;
	}

	.trap-icon {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		font-size: 0.875rem;
		font-weight: 700;
		color: #9a3412;
		background: #ffedd5;
		border-radius: 50%;
	}

	.trap-content h3 {
		margin: 0 0 0.25rem;
		font-size: clamp(0.9375rem, 1vw + 0.75rem, 1rem);
		font-weight: 600;
		color: #7c2d12;
	}

	.trap-content p {
		margin: 0;
		font-size: clamp(0.8125rem, 1vw + 0.65rem, 0.9375rem);
		color: #9a3412;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.service-card {
			transition: none;
		}

		.service-card:hover {
			transform: none;
		}
	}

	/* Tablet: 768px+ */
	@media (min-width: 768px) {
		.hero {
			padding-block: 2rem 2.75rem;
		}

		.services,
		.traps {
			padding-block: 2.75rem;
		}

		.section-lead {
			margin-bottom: 1.5rem;
		}

		.card-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1rem;
		}

		.service-card {
			padding: 1.125rem 1.25rem;
		}

		.trap-list {
			gap: 0.75rem;
		}

		.trap-item {
			gap: 1rem;
			padding: 1rem 1.25rem;
		}

		.trap-icon {
			width: 1.75rem;
			height: 1.75rem;
			font-size: 1rem;
		}
	}

	/* Desktop: 1280px+ */
	@media (min-width: 1280px) {
		.hero {
			padding-block: 2.5rem 3.5rem;
		}

		.services,
		.traps {
			padding-block: 3.5rem;
		}

		.section-lead {
			margin-bottom: 1.75rem;
		}

		.card-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.25rem;
		}

		.service-card {
			padding: 1.25rem 1.5rem;
		}

		.card-limit {
			margin-top: 0.5rem;
			padding-top: 0.75rem;
		}
	}
</style>
