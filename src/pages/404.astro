---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="404 — Page Not Found"
	description="The page you're looking for doesn't exist. Head back to the AWS Free Tier Survival Guide."
>
	<section class="not-found" aria-labelledby="not-found-heading">
		<p class="not-found-code" aria-hidden="true">404</p>
		<h1 id="not-found-heading">Page Not Found</h1>
		<p class="not-found-message">
			Sorry, we couldn't find that page. It may have been moved or the link might be
			outdated.
		</p>
		<a href="/" class="home-link">Back to homepage</a>
	</section>
</Layout>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding-block: 3rem 4rem;
		max-width: 32rem;
		margin-inline: auto;
	}

	.not-found-code {
		margin: 0 0 0.5rem;
		font-size: clamp(3rem, 10vw, 4.5rem);
		font-weight: 700;
		line-height: 1;
		letter-spacing: -0.03em;
		color: var(--color-border, #e5e5e5);
	}

	h1 {
		margin: 0 0 0.75rem;
		font-size: clamp(1.375rem, 3vw + 0.5rem, 1.75rem);
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--color-text, #1a1a1a);
	}

	.not-found-message {
		margin: 0 0 1.75rem;
		font-size: clamp(0.875rem, 1.5vw + 0.5rem, 1rem);
		color: var(--color-text-muted, #5c5c5c);
	}

	.home-link {
		display: inline-block;
		padding: 0.625rem 1.25rem;
		font-size: 0.9375rem;
		font-weight: 600;
		color: #ffffff;
		background-color: var(--color-accent, #2563eb);
		border-radius: 0.375rem;
		text-decoration: none;
		transition: background-color 0.2s ease;
	}

	.home-link:hover {
		background-color: #1d4ed8;
	}

	.home-link:focus-visible {
		outline: 2px solid var(--color-accent, #2563eb);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.home-link {
			transition: none;
		}
	}
</style>
